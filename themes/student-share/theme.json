{
  "name": "student-share",
  "displayName": "学员经验分享",
  "version": "1.1.0",
  "description": "适用于学员个人经历分享类文章（保研、读博、转行等）。自动生成 Part.XX 章节编号 + 章节头图 banner，自动注入开头动图 / 分割线 / 引流二维码 / 关注尾图，封面基于学员 frontmatter 字段合成。",
  "category": "学员故事",
  "headingStyle": "part-number",
  "autoInject": {
    "header": "assets/opening.gif",
    "footerMarkdown": "assets/footer.md"
  },
  "cover": {
    "type": "template",
    "base": "assets/cover-base.png",
    "width": 1770,
    "height": 795,
    "masks": [
      { "x": 365, "y": 130, "width": 540, "height": 130, "color": "#F9DA04", "rx": 18 }
    ],
    "overlays": [
      { "field": "tagline", "x": 635, "y": 148, "size": 54, "color": "#000000", "weight": 900, "anchor": "middle", "maxWidth": 540, "font": "'PingFang SC', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif" }
    ]
  },
  "headingBanner": {
    "enabled": true,
    "width": 1123,
    "height": 437,
    "english": { "font": "Georgia, 'Times New Roman', serif", "size": 208, "color": "#111111", "top": 60, "align": "middle" },
    "chinese": { "font": "'PingFang SC', 'Noto Sans CJK SC', sans-serif", "size": 60, "weight": 900, "color": "#111111", "top": 320, "align": "middle" }
  }
}
